{
  "name": "cryptoniumpay-worker-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create cryptoniumpay-db",
    "db:migrate": "wrangler d1 execute cryptoniumpay-db --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute cryptoniumpay-db --local --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0"
  }
}