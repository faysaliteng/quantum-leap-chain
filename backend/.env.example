# ── Cryptoniumpay Backend — Environment Variables ──
# Copy this file to .env and fill in all values

# ── Core ──
NODE_ENV=production
PORT=3000

# ── Database ──
DATABASE_URL=postgresql://cryptoniumpay:CHANGE_ME@db:5432/cryptoniumpay?schema=public

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── JWT ──
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Signer Service ──
SIGNER_URL=http://signer:3001
SIGNER_SECRET=CHANGE_ME_SIGNER_SECRET

# ── CORS ──
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Blockchain Watcher ──
ENABLE_WATCHER=true

# ── Exports ──
EXPORT_DIR=/data/exports

# ── Postgres (for docker-compose) ──
POSTGRES_USER=cryptoniumpay
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cryptoniumpay
